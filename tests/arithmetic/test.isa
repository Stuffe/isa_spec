[settings]
endianness = little


[instructions]

add %a:S8(immediate), %b:S8(immediate)
%c = %a + %b
cccccccc 00000000

sub %a:S8(immediate), %b:S8(immediate)
%c = %a - %b
cccccccc 00000001

mul %a:S8(immediate), %b:S8(immediate)
%c = %a * %b
cccccccc 00000010

div %a:S8(immediate), %b:S8(immediate)
%c = %a / %b
cccccccc 00000011

mod %a:S8(immediate), %b:S8(immediate)
%c = %a % %b
cccccccc 00000100

and %a:S8(immediate), %b:S8(immediate)
%c = %a & %b
cccccccc 00000101

or %a:S8(immediate), %b:S8(immediate)
%c = %a | %b
cccccccc 00000110

xor %a:S8(immediate), %b:S8(immediate)
%c = %a ^ %b
cccccccc 00000111

lsl %a:S8(immediate), %b:S8(immediate)
%c = %a << %b
cccccccc 00001000

lsr %a:S8(immediate), %b:S8(immediate)
%c = %a >> %b
cccccccc 00001001

asr %a:S8(immediate), %b:S8(immediate)
%c = asr(%a, %b)
cccccccc 00001010

log2 %a:S8(immediate)
%b = log2(%a)
bbbbbbbb 00001011
