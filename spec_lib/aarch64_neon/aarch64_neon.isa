[patterns]

; Prefetch operation in either verbose or immediate modes
@prf_op_imm(`size`)
%_(pound)%imm:U`size`(immediate)
%imm

@prf_op_safe
%p(prf_op_type_range)%r(prf_op_target_range)%f(prf_op_policy)
prrf

@prf_op_sys
%p(prf_op_type_range)%f(prf_op_policy_range)
ffffp

@prf_op_range
%p(prf_op_type_range)%r(prf_op_target)%f(prf_op_policy)
pprrf

@prf_op_ir
%prf:U5(prf_op_ir)
%prf

@prf_op4
%pattern(@prf_op_safe|@prf_op_imm(4))
%pattern

@prf_op5
%pattern(@prf_op_sys|@prf_op_imm(5))
%pattern

@prf_op6
%pattern(@prf_op_range|@prf_op_imm(6))
%pattern

@reg_sys_0
%pattern(reg_sys)
%pattern

@reg_sys_1
s%op0:U1(reg_sys_op0)_%op1:U3(reg_sys_op12)_%crn:U4(reg_sys_cr)_%crm:U4(reg_sys_cr)_%op2:U3(reg_sys_op12)
%op0 %op1 %crn %crm %op2

@reg_sys
%pattern(@reg_sys_0|@reg_sys_1)
%pattern

@mask_za_

#x00

@mask_za_0
%t0(mask_za)
%t0[7:0]

@mask_za_1
%t0(mask_za) , %t1(mask_za)
%t:U8 = %t0 | %t1
%t

@mask_za_2
%t0(mask_za) , %t1(mask_za) , %t2(mask_za)
%t:U8 = %t0 | %t1 | %t2
%t

@mask_za_3
%t0(mask_za) , %t1(mask_za) , %t2(mask_za) , %t3(mask_za)
%t:U8 = %t0 | %t1 | %t2 | %t3
%t

@mask_za_5
%t0(mask_za) , %t1(mask_za) , %t2(mask_za) , %t3(mask_za) , %t4(mask_za)
%t:U8 = %t0 | %t1 | %t2 | %t3 | %t4
%t

@mask_za_5
%t0(mask_za) , %t1(mask_za) , %t2(mask_za) , %t3(mask_za) , %t4(mask_za) , %t5(mask_za)
%t:U8 = %t0 | %t1 | %t2 | %t3 | %t4 | %t5
%t

@mask_za_6
%t0(mask_za) , %t1(mask_za) , %t2(mask_za) , %t3(mask_za) , %t4(mask_za) , %t5(mask_za) , %t6(mask_za)
%t:U8 = %t0 | %t1 | %t2 | %t3 | %t4 | %t5 | %t6
%t

@mask_za_7
%t0(mask_za) , %t1(mask_za) , %t2(mask_za) , %t3(mask_za) , %t4(mask_za) , %t5(mask_za) , %t6(mask_za) , %t7(mask_za)
%t:U8 = %t0 | %t1 | %t2 | %t3 | %t4 | %t5 | %t6 | %t7
%t

@mask_za
%pattern(@mask_za_ | @mask_za_0 | @mask_za_1 | @mask_za_2 | @mask_za_3 | @mask_za_4 | @mask_za_5 | @mask_za_6 | @mask_za_7)
%pattern

[instructions]

; Generated from https://developer.arm.com/documentation/ddi0602/2025-06/Base-Instructions/ABS--Absolute-value-
abs  w%d(reg_sf) , w%n(reg_sf)
0 1 0 11010110 00000 001000 %n[4:0] %d[4:0]
# Absolute value

abs  x%t(reg_sf) , x%p(reg_sf)
1 1 0 11010110 00000 001000 %p[4:0] %t[4:0]
# Absolute value

; Generated from https://developer.arm.com/documentation/ddi0602/2025-06/Base-Instructions/ADCS--Add-with-carry--setting-flags-
adcs  w%d(reg_sf) , w%n(reg_sf) , w%m(reg_sf)
0 0 1 11010000 %m[4:0] 000000 %n[4:0] %d[4:0]
# Add with carry, setting flags

adcs  x%t(reg_sf) , x%p(reg_sf) , x%q(reg_sf)
1 0 1 11010000 %q[4:0] 000000 %p[4:0] %t[4:0]
# Add with carry, setting flags

; Generated from https://developer.arm.com/documentation/ddi0602/2025-06/Base-Instructions/ADC--Add-with-carry-
adc  w%d(reg_sf) , w%n(reg_sf) , w%m(reg_sf)
0 0 0 11010000 %m[4:0] 000000 %n[4:0] %d[4:0]
# Add with carry

adc  x%t(reg_sf) , x%p(reg_sf) , x%q(reg_sf)
1 0 0 11010000 %q[4:0] 000000 %p[4:0] %t[4:0]
# Add with carry

; Generated from https://developer.arm.com/documentation/ddi0602/2025-06/Base-Instructions/ADDG--Add-with-tag-
addg  %d(reg_sp_64) , %n(reg_sp_64) , %_(pound)%imm6(<U10>immediate) , %_(pound)%imm4(<U4>immediate)
if %imm6 % 0x10 != 0 {
    "%imm6 must be a multiple of 16"
}
%imm6 = %imm6 / 0x10
1 0 0 1000110 %imm6[5:0] 00 %imm4[3:0] %n[4:0] %d[4:0]
# Add with tag

; Generated from https://developer.arm.com/documentation/ddi0602/2025-06/Base-Instructions/ADDPT--Add-checked-pointer-
addpt  %d(reg_sp_64) , %n(reg_sp_64) , x%m(reg_sf)
