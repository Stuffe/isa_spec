eor  %d(reg_sp_32) , w%n(reg_sf) , %_(pound)%imm(immediate)
if %imm == 0 || %imm == -1 {
    "Bit mask immediate not encodeable"
}
%rot = trailing_zeros(%imm & (%imm + 1)) & 0x3F
%norm = (%imm >> %rot) | (%imm << (64 - %rot))
%zeroes = 63 - log2(%norm)
%ones = trailing_zeros(%norm ^ -1)
%size = %zeroes + %ones
if ((%imm >> %size) | (%imm << (64 - %size))) != %imm {
    "Bit mask immediate not encodeable"
}
%N = %size >> 6
%imms = ((0 - (%size << 1)) | (%ones - 1)) & 0x3F
%immr = (0 - %rot) & (%size - 1)
if %N != 0 {
    "%N must be 0 for 32-bit variant"
}
0 10 100100 0 %immr[5:0] %imms[5:0] %n[4:0] %d[4:0]
# Bitwise exclusive-OR (immediate)

eor  %t(reg_sp_64) , x%p(reg_sf) , %_(pound)%imm(immediate)
if %imm == 0 || %imm == -1 {
    "Bit mask immediate not encodeable"
}
%rot = trailing_zeros(%imm & (%imm + 1)) & 0x3F
%norm = (%imm >> %rot) | (%imm << (64 - %rot))
%zeroes = 63 - log2(%norm)
%ones = trailing_zeros(%norm ^ -1)
%size = %zeroes + %ones
if ((%imm >> %size) | (%imm << (64 - %size))) != %imm {
    "Bit mask immediate not encodeable"
}
%N = %size >> 6
%imms = ((0 - (%size << 1)) | (%ones - 1)) & 0x3F
%immr = (0 - %rot) & (%size - 1)
1 10 100100 %N[0:0] %immr[5:0] %imms[5:0] %p[4:0] %t[4:0]
# Bitwise exclusive-OR (immediate)

